# Local build defaults. Copy to `.env` and fill in local-only values.
#
# The TLS bootstrap certificate/key are build-time secrets used by the native
# ESP-IDF HTTPS server. Prefer the *_B64 variables in CI secrets to avoid
# multiline quoting issues. Locally, either form is accepted.

# QUOTES_CLOCK_SERIAL_PORT=/dev/ttyUSB0
# QUOTES_CLOCK_SERIAL_PORT=COM6

# QUOTES_CLOCK_TLS_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# QUOTES_CLOCK_TLS_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# QUOTES_CLOCK_TLS_CERT_PEM_B64=
# QUOTES_CLOCK_TLS_KEY_PEM_B64=
